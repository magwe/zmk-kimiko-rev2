// See https://zmk.dev/docs/development/hardware-integration/physical-layouts
// for how to configure this.

#include <physical_layouts.dtsi>

/ {
    default_layout: default_layout {
        compatible = "zmk,physical-layout";
        display-name = "Default Layout";
        transform = <&default_transform>;
        kscan = <&kscan>;

        // Edit this to define the positions and sizes of the keys, or remove it
        // if your keyboard will not support ZMK Studio.
        // https://zmk.dev/docs/development/hardware-integration/physical-layouts#optional-keys-property

        keys  //                     w   h    x    y     rot    rx    ry
            = <&key_physical_attrs 100 100    0   96       0     0     0>
            , <&key_physical_attrs 100 100  100   96       0     0     0>
            , <&key_physical_attrs 100 100  200   31       0     0     0>
            , <&key_physical_attrs 100 100  300    0       0     0     0>
            , <&key_physical_attrs 100 100  400   31       0     0     0>
            , <&key_physical_attrs 100 100  500   46       0     0     0>
            , <&key_physical_attrs 100 100 1200   45       0     0     0>
            , <&key_physical_attrs 100 100 1300   31       0     0     0>
            , <&key_physical_attrs 100 100 1400    0       0     0     0>
            , <&key_physical_attrs 100 100 1500   31       0     0     0>
            , <&key_physical_attrs 100 100 1600   96       0     0     0>
            , <&key_physical_attrs 100 100 1700   96       0     0     0>
            , <&key_physical_attrs 100 100    0  196       0     0     0>
            , <&key_physical_attrs 100 100  100  196       0     0     0>
            , <&key_physical_attrs 100 100  200  131       0     0     0>
            , <&key_physical_attrs 100 100  300  100       0     0     0>
            , <&key_physical_attrs 100 100  400  131       0     0     0>
            , <&key_physical_attrs 100 100  500  146       0     0     0>
            , <&key_physical_attrs 100 100 1200  146       0     0     0>
            , <&key_physical_attrs 100 100 1300  131       0     0     0>
            , <&key_physical_attrs 100 100 1400  100       0     0     0>
            , <&key_physical_attrs 100 100 1500  131       0     0     0>
            , <&key_physical_attrs 100 100 1600  196       0     0     0>
            , <&key_physical_attrs 100 100 1700  196       0     0     0>
            , <&key_physical_attrs 100 100    0  296       0     0     0>
            , <&key_physical_attrs 100 100  100  296       0     0     0>
            , <&key_physical_attrs 100 100  200  231       0     0     0>
            , <&key_physical_attrs 100 100  300  200       0     0     0>
            , <&key_physical_attrs 100 100  400  231       0     0     0>
            , <&key_physical_attrs 100 100  500  246       0     0     0>
            , <&key_physical_attrs 100 100 1200  246       0     0     0>
            , <&key_physical_attrs 100 100 1300  231       0     0     0>
            , <&key_physical_attrs 100 100 1400  200       0     0     0>
            , <&key_physical_attrs 100 100 1500  231       0     0     0>
            , <&key_physical_attrs 100 100 1600  296       0     0     0>
            , <&key_physical_attrs 100 100 1700  296       0     0     0>
            , <&key_physical_attrs 100 100    0  396       0     0     0>
            , <&key_physical_attrs 100 100  100  400       0     0     0>
            , <&key_physical_attrs 100 100  200  331       0     0     0>
            , <&key_physical_attrs 100 100  300  300       0     0     0>
            , <&key_physical_attrs 100 100  400  331       0     0     0>
            , <&key_physical_attrs 100 100  500  346       0     0     0>
            , <&key_physical_attrs 100 100  350  330    3000   400   900>
            , <&key_physical_attrs 100 100  350  330    4500   400   900>
            , <&key_physical_attrs 100 100 1360  330 (-4500)  1410   900>
            , <&key_physical_attrs 100 100 1360  330 (-3000)  1410   900>
            , <&key_physical_attrs 100 100 1200  346       0     0     0>
            , <&key_physical_attrs 100 100 1300  331       0     0     0>
            , <&key_physical_attrs 100 100 1400  300       0     0     0>
            , <&key_physical_attrs 100 100 1500  331       0     0     0>
            , <&key_physical_attrs 100 100 1600  396       0     0     0>
            , <&key_physical_attrs 100 100 1700  396       0     0     0>
            , <&key_physical_attrs 100 100  250  430       0     0     0>
            , <&key_physical_attrs 100 100  350  430       0     0     0>
            , <&key_physical_attrs 100 100  350  430    1500   400   900>
            , <&key_physical_attrs 100 100  350  430    3000   400   900>
            , <&key_physical_attrs 100 100  350  430    4500   400   900>
            , <&key_physical_attrs 100 100 1360  430 (-4500)  1410   900>
            , <&key_physical_attrs 100 100 1360  430 (-3000)  1410   900>
            , <&key_physical_attrs 100 100 1360  430 (-1500)  1410   900>
            , <&key_physical_attrs 100 100 1360  430       0     0     0>
            , <&key_physical_attrs 100 100 1460  430       0     0     0>
            ;
    };
};
